                    "id": "obj-38",
                    "maxclass": "newobj",
                    "numinlets": 3,
                    "numoutlets": 1,
                    "outlettype": [ "signal" ],
                    "patching_rect": [ 1585.0, 641.0, 90.0, 23.0 ],
                    "rnbo_classname": "gen~",
                    "rnbo_extra_attributes": {
                        "exposeparams": 0,
                        "gencode": "SineEaseInOut(value) {\n\treturn 0.5 * ((1 - (cos(value * PI))));\n}\n\nParam selection(0, max=3, default=1, min=1);\nParam ramptime_ms(0, max=1000, default=100, min=0);\nHistory history_1(0);\nHistory history_2(0);\nrdiv_3 = 1000/samplerate / ramptime_ms;\nneg_4 = -rdiv_3;\neq_5 = history_1 == 1;\neq_6 = history_1 == 0;\nlatch_7 = latch(selection, eq_6);\nselector_8 = selector(latch_7, in1, in2, in3);\nlatch_9 = latch(latch_7, eq_5);\nselector_10 = selector(latch_9, in1, in2, in3);\nneq_11 = latch_9 != latch_7;\nsub_12 = neq_11 - history_2;\nclamp_13 = clamp(sub_12, neg_4, rdiv_3);\nadd_14 = clamp_13 + history_2;\nexpr_15 = SineEaseInOut(add_14);\nmix_16 = mix(selector_10, selector_8, expr_15);\nout1 = mix_16;\nhistory_1_next_17 = fixdenorm(add_14);\nhistory_2_next_18 = fixdenorm(add_14);\nhistory_1 = history_1_next_17;\nhistory_2 = history_2_next_18;",
                        "geninlets": 3,
                        "genoutlets": 1
                    },
                    "rnbo_serial": 2,
                    "rnbo_uniqueid": "gen~_obj-38",
                    "rnboinfo": {
